# Setup:
# 1. Create a Supabase project and copy the Postgres connection string here.
# 2. Put the Supabase auth URL and anon key here.
# 3. Run `npx prisma generate`, then `npx prisma migrate dev`, then `npx prisma db seed`.

DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional for future server-only admin jobs:
SUPABASE_SERVICE_ROLE_KEY=
